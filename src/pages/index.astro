---
import '../styles/global.css';
import site from '../../site.json';
import Media from '../components/Media.astro';
import Globe from '../components/Globe.astro';
import { readPosts, REACTION_EMOJIS, REACTION_EMOJIS_REPLY } from '../lib/store';
import { findCountry } from '../lib/countries';

const posts = (await readPosts()).sort((a, b) => b.createdAt.localeCompare(a.createdAt));
const fmt = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

// Open Graph unfurl: latest post's first photo + caption. SITE_URL env needed in prod
// for absolute image URLs (the node adapter can't know its public origin behind nginx).
const origin = (process.env.SITE_URL ?? Astro.url.origin).replace(/\/$/, '');
const latest = posts[0];
const ogDescription = latest
  ? [fmt(latest.createdAt), latest.title, latest.caption].filter(Boolean).join(' — ').slice(0, 200)
  : site.tagline;

// >6 photos → horizontal 2-row scroller packed into full-height COLUMNS, so the block is always
// an even rectangle (no ragged end) with no double-height images in the middle.
//   - A landscape is one full-width "cell"; two portraits pack side-by-side into one cell the
//     same width. Portraits pair GLOBALLY (one can wait across a landscape for its partner) so at
//     most one portrait is ever left over in the whole post. Everything is cover-cropped.
//   - Cells stack two-high into columns. The first photo, a leftover cell, and the one possible
//     odd portrait each go double-height to keep the box closed.
type Images = (typeof posts)[number]['images'];
type Img = Images[number];
type Cell = Img[]; // one landscape, or two portraits (each half a landscape wide)
type Column = { kind: 'big'; img: Img } | { kind: 'stack'; top: Cell; bottom: Cell } | { kind: 'tall'; cell: Cell };
const landscape = (img: Img) => img.w >= img.h;
const buildColumns = (images: Images): Column[] => {
  if (!images.length) return [];
  const cols: Column[] = [{ kind: 'big', img: images[0] }]; // hero
  const cells: Cell[] = [];
  let stash: Img | null = null; // a lone portrait waiting for a partner
  for (const img of images.slice(1)) {
    if (landscape(img)) cells.push([img]);
    else if (stash) (cells.push([stash, img]), (stash = null));
    else stash = img;
  }
  // pair complete cells into full stack columns; keep the final odd cell (if any) as `last`
  let i = 0;
  for (; i + 1 < cells.length; i += 2) cols.push({ kind: 'stack', top: cells[i], bottom: cells[i + 1] });
  const last = i < cells.length ? cells[i] : null;
  // Lay out whatever's left over without piling up double-height images: a leftover landscape
  // cell goes double-height, but leftover portraits pair up VERTICALLY into normal-height 160px
  // columns, and only the one unavoidable odd portrait (2 rows can't hold an odd count) is doubled.
  const tail: Img[] = [];
  if (last && landscape(last[0])) cols.push({ kind: 'tall', cell: last });
  else if (last) tail.push(...last);
  if (stash) tail.push(stash);
  for (let k = 0; k + 1 < tail.length; k += 2) cols.push({ kind: 'stack', top: [tail[k]], bottom: [tail[k + 1]] });
  if (tail.length % 2) cols.push({ kind: 'big', img: tail[tail.length - 1] });
  return cols;
};
// fixed widths: a landscape must equal two portraits PLUS the 1px gap-px between them (160+1+160
// = 321) so a paired-portrait row lines up exactly with a landscape row in the same stack column.
const singleW = (img: Img) => (landscape(img) ? 'w-[321px]' : 'w-[160px]');
const doubleW = (img: Img) => (landscape(img) ? 'w-[640px]' : 'w-[320px]');
const fade = 'transition-opacity duration-200 hover:opacity-85';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.name} — {site.subtitle}</title>
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/assets/icon-256.png" type="image/png" sizes="256x256" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content={site.name} />
    <meta property="og:title" content={`${site.name} ${site.subtitle}`} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={`${origin}/og.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={origin + '/'} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Butterfly+Kids&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-neutral-800 antialiased">
    <header class="py-7 text-center">
      <img src="/assets/icon-256.png" alt="" class="h-16 w-16 mx-auto" />
      <h1 class="font-hand text-6xl text-neutral-900 mt-[-20px]">
        {site.name}
      </h1>
      <h2 class="font-hand text-5xl text-neutral-900">{site.subtitle}</h2>
      <p class="mt-2">{site.tagline}</p>
      <p class="mt-5 "><a href="/about" class="underline text-neutral-500 hover:text-neutral-900">About us</a></p>
    </header>

    {posts.length > 0 && (
      <div id="notify" class="mb-12 text-center opacity-0 h-20px">
        <button
          id="notify-btn"
          class="cursor-pointer rounded-full border border-neutral-300 px-5 py-2 text-sm font-medium text-neutral-700 transition-colors hover:bg-neutral-100"
        ></button>
        <p id="notify-msg" class="mt-2 text-sm text-neutral-400"></p>
      </div>
    )}

    <main class="space-y-24 pb-24">
      {posts.length === 0 && <p class="text-center text-neutral-400">Nothing here yet.</p>}
      {
        posts.map((post) => {
          // globe pin: the album's GPS if we have it, else the picked country's centroid
          const place =
            post.lat != null && post.lng != null ? { lat: post.lat, lng: post.lng } : findCountry(post.country);
          return (
          <article id={`post-${post.id}`}>
            {place && <div class="mb-2"><Globe point={place} /></div>}
            <p class="mb-3 text-center text-xs tracking-[0.2em] text-neutral-400 uppercase">
              <time datetime={post.createdAt}>{fmt(post.createdAt)}</time>
              {post.title && <span class="text-neutral-600"> &mdash; {post.title}</span>}
            </p>
            {post.images.length > 6 ? (
              <div class="overflow-x-auto">
                <div class="mx-auto flex w-max gap-px">
                  {buildColumns(post.images).map((col) =>
                    col.kind === 'big' ? (
                      <Media item={col.img} cover class={`h-[481px] ${doubleW(col.img)} ${fade}`} />
                    ) : col.kind === 'tall' ? (
                      <div class="flex gap-px">
                        {col.cell.map((img) => <Media item={img} cover class={`h-[481px] ${doubleW(img)} ${fade}`} />)}
                      </div>
                    ) : (
                      <div class="flex flex-col gap-px">
                        <div class="flex gap-px">
                          {col.top.map((img) => <Media item={img} cover class={`h-60 ${singleW(img)} ${fade}`} />)}
                        </div>
                        <div class="flex gap-px">
                          {col.bottom.map((img) => <Media item={img} cover class={`h-60 ${singleW(img)} ${fade}`} />)}
                        </div>
                      </div>
                    ),
                  )}
                </div>
              </div>
            ) : (
              <div class="gallery">
                {post.images.map((img) => (
                  <Media item={img} class="transition-opacity duration-200 hover:opacity-85" />
                ))}
              </div>
            )}
            <div class="mx-auto mt-6 max-w-2xl px-4">
              {post.caption && (
                <p class="whitespace-pre-wrap text-[17px] leading-relaxed text-neutral-700">{post.caption}</p>
              )}
              <p class="font-hand mt-3 text-3xl text-neutral-700">- {post.author || site.defaultAuthor}</p>

              

<hr />
<div class="reactions mt-4 flex flex-wrap justify-start gap-1 ml-[-8px]" data-id={post.id}>
                {REACTION_EMOJIS.map((e) => (
                  <button
                    data-emoji={e}
                    class="cursor-pointer rounded-full px-2.5 py-1 text-lg transition-colors hover:bg-neutral-200/70"
                  >
                    {e}
                    <span class="align-middle text-xs text-neutral-500">{post.reactions?.[e] || ''}</span>
                  </button>
                ))}
              </div>
              {(post.comments?.length ?? 0) > 0 && (
                <div class="mt-6 space-y-3 text-left text-sm">
                  {post.comments!.map((c) => (
                    <div class="comment group relative" data-post={post.id} data-key={c.createdAt}>
                      <div class="react-bubble absolute bottom-full left-2 z-10 hidden items-center gap-0.5 rounded-full border border-neutral-200 bg-white px-1.5 py-1 shadow-lg">
                        {REACTION_EMOJIS_REPLY.map((e) => (
                          <button type="button" data-emoji={e} class="cursor-pointer rounded-full px-1 text-lg leading-none transition-transform hover:scale-125">
                            {e}
                          </button>
                        ))}
                        <button type="button" class="bubble-reply ml-0.5 cursor-pointer rounded-full px-2 text-xs font-medium text-neutral-500 hover:bg-neutral-100">
                          Reply
                        </button>
                      </div>
                      <p class="comment-text cursor-pointer hover:text-neutral-950">
                        <span class="font-semibold text-neutral-800">{c.name} said:</span>{' '}
                        <span class="whitespace-pre-wrap text-neutral-600">{c.text}</span>
                      </p>
                      <p class="creaction-summary mt-0.5 flex gap-2 text-xs text-neutral-400" hidden={!c.reactions}>
                        {c.reactions &&
                          Object.entries(c.reactions).map(([e, n]) => (
                            <span>
                              {e} {n}
                            </span>
                          ))}
                      </p>
                      {c.replies?.map((r) => (
                        <p class="mt-1 ml-4 border-l-2 border-neutral-200 pl-3">
                          <span class="font-semibold text-neutral-800">{r.name}:</span>{' '}
                          <span class="whitespace-pre-wrap text-neutral-600">{r.text}</span>
                        </p>
                      ))}
                      <form method="post" action="/api/reply" class="reply-form mt-2 ml-4 hidden space-y-2">
                          <input type="hidden" name="id" value={post.id} />
                          <input type="hidden" name="commentId" value={c.createdAt} />
                          <input type="hidden" name="authorId" />
                          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" />
                          <input
                            name="name"
                            required
                            maxlength="50"
                            placeholder="Your name"
                            class="block w-full rounded-lg border border-neutral-300 px-3 py-1.5 focus:border-neutral-500 focus:outline-none"
                          />
                          <textarea
                            name="text"
                            required
                            maxlength="1000"
                            rows="2"
                            placeholder={`Reply to ${c.name}…`}
                            class="block w-full rounded-lg border border-neutral-300 px-3 py-1.5 focus:border-neutral-500 focus:outline-none"
                          ></textarea>
                          <div class="flex gap-2">
                            <button class="cursor-pointer rounded-lg bg-neutral-900 px-4 py-1.5 font-medium text-white hover:bg-neutral-700">
                              Reply
                            </button>
                            <button type="button" class="reply-cancel cursor-pointer rounded-lg px-4 py-1.5 font-medium text-neutral-500 hover:bg-neutral-100">
                              Cancel
                            </button>
                          </div>
                        </form>
                    </div>
                  ))}
                </div>
              )}
              
              <details class="mt-4 text-left text-sm">
                <summary class="cursor-pointer text-neutral-400 select-none hover:text-neutral-600">
                  Leave a comment
                </summary>
                <form method="post" action="/api/comment" class="mt-3 space-y-2">
                  <input type="hidden" name="id" value={post.id} />
                  <input type="hidden" name="authorId" />
                  <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" />
                  <input
                    name="name"
                    required
                    maxlength="50"
                    placeholder="Your name"
                    class="block w-full rounded-lg border border-neutral-300 px-3 py-1.5 focus:border-neutral-500 focus:outline-none"
                  />
                  <textarea
                    name="text"
                    required
                    maxlength="1000"
                    rows="2"
                    placeholder="Say something nice"
                    class="block w-full rounded-lg border border-neutral-300 px-3 py-1.5 focus:border-neutral-500 focus:outline-none"
                  ></textarea>
                  <div class="flex gap-2">
                    <button class="cursor-pointer rounded-lg bg-neutral-900 px-4 py-1.5 font-medium text-white hover:bg-neutral-700">
                      Post comment
                    </button>
                    <button type="button" class="comment-cancel cursor-pointer rounded-lg px-4 py-1.5 font-medium text-neutral-500 hover:bg-neutral-100">
                      Cancel
                    </button>
                  </div>
                </form>
              </details>
            </div>
          </article>
          );
        })
      }
    </main>

    <footer class="pb-10 text-center text-sm text-neutral-400">
      
      <p style="line-height: 0.1em;">made with</p>
      <p><a
        href="https://github.com/squarecat/squarecat-a-gram"
        class="font-hand align-middle text-2xl text-neutral-600 hover:text-neutral-900"
      >Squarecat-a-gram</a></p>
      <p class="mt-3">
        <a
          href="https://github.com/squarecat/squarecat-a-gram"
          aria-label="Squarecat-a-gram on GitHub"
          class="inline-block text-neutral-400 hover:text-neutral-900"
        >
          <svg viewBox="0 0 16 16" width="22" height="22" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        </a>
      </p>
    </footer>

    <dialog
      id="lightbox"
      class="fixed inset-0 m-0 h-dvh max-h-none w-screen max-w-none touch-none bg-transparent p-0 select-none backdrop:bg-neutral-950/95"
    >
      <div id="lb-spin" hidden class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
        <div class="lb-spinner"></div>
      </div>
      <img id="lb-img" alt="" draggable="false" class="h-full w-full object-contain px-2 pt-2 pb-16 sm:px-6 sm:pt-6" />
      <video
        id="lb-vid"
        controls
        playsinline
        hidden
        class="h-full w-full object-contain px-2 pt-2 pb-16 sm:px-6 sm:pt-6"
      ></video>
      <button
        id="lb-play"
        aria-label="Play video"
        hidden
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 cursor-pointer"
      >
        <svg width="76" height="76" viewBox="0 0 46 46" aria-hidden="true">
          <circle cx="23" cy="23" r="23" fill="rgba(0,0,0,0.5)" />
          <path d="M19 15l13 8-13 8z" fill="#fff" />
        </svg>
      </button>
      <button
        id="lb-close"
        aria-label="Close"
        class="absolute top-3 right-4 cursor-pointer text-3xl leading-none text-white/70 hover:text-white"
      >&times;</button>
      <div id="lb-nav" class="absolute bottom-3 left-1/2 flex -translate-x-1/2 items-center gap-6 text-white/70">
        <button id="lb-prev" aria-label="Previous" class="cursor-pointer px-2 text-3xl leading-none hover:text-white">&lsaquo;</button>
        <span id="lb-count" class="text-sm tracking-widest tabular-nums"></span>
        <button id="lb-next" aria-label="Next" class="cursor-pointer px-2 text-3xl leading-none hover:text-white">&rsaquo;</button>
      </div>
    </dialog>

    <script>
      const dialog = document.getElementById('lightbox') as HTMLDialogElement;
      const full = document.getElementById('lb-img') as HTMLImageElement;
      const vid = document.getElementById('lb-vid') as HTMLVideoElement;
      const play = document.getElementById('lb-play') as HTMLButtonElement;
      let group: HTMLImageElement[] = [];
      let idx = 0;
      let scrollY = 0;

      const count = document.getElementById('lb-count')!;
      const lbSpin = document.getElementById('lb-spin')!;
      // hide the lightbox spinner once the full image has painted (or if it errors)
      full.addEventListener('load', () => (lbSpin.hidden = true));
      full.addEventListener('error', () => (lbSpin.hidden = true));

      // iOS Safari resolves h-dvh to the LARGE viewport for a top-layer <dialog>, so the
      // box overflows the visible screen and object-contain pushes the photo up under the
      // address bar. window.innerHeight is reported correctly — size the dialog from it.
      const sizeToViewport = () => (dialog.style.height = `${window.innerHeight}px`);
      window.addEventListener('resize', () => dialog.open && sizeToViewport());

      function show(i: number) {
        idx = (i + group.length) % group.length;
        const el = group[idx];
        // always show the still (poster for videos) — video only loads when Play is tapped,
        // so you can swipe past a video without it grabbing the gesture
        vid.pause();
        vid.hidden = true;
        vid.removeAttribute('src');
        full.hidden = false;
        lbSpin.hidden = false; // spinner until the full image loads
        full.src = el.dataset.full || el.src; // load the full-size image, not the grid thumb
        play.hidden = !el.dataset.video;
        count.textContent = `${idx + 1} / ${group.length}`;
        // preload neighbouring full images (not videos) so paging feels instant
        for (const n of [idx + 1, idx - 1]) {
          const nb = group[(n + group.length) % group.length];
          if (!nb.dataset.video) new Image().src = nb.dataset.full || nb.src;
        }
      }

      play.addEventListener('click', () => {
        const src = group[idx].dataset.video;
        if (!src) return;
        play.hidden = true;
        full.hidden = true;
        vid.hidden = false;
        vid.src = src;
        vid.play().catch(() => {}); // user-initiated, but ignore if the browser still blocks
      });

      // hide each feed image's spinner once it has loaded
      for (const img of document.querySelectorAll<HTMLImageElement>('.media img')) {
        const done = () => img.closest('.media')?.classList.add('loaded');
        if (img.complete) done();
        else {
          img.addEventListener('load', done);
          img.addEventListener('error', done);
        }
      }

      // paging stays within the clicked post
      for (const article of document.querySelectorAll('article')) {
        const imgs = [...article.querySelectorAll<HTMLImageElement>('img.lightboxable')];
        imgs.forEach((img, i) =>
          img.addEventListener('click', () => {
            group = imgs;
            show(i);
            scrollY = window.scrollY; // overflow:hidden toggle resets scroll; restore on close
            sizeToViewport();
            dialog.showModal();
          }),
        );
      }

      document.getElementById('lb-close')!.addEventListener('click', () => dialog.close());
      document.getElementById('lb-prev')!.addEventListener('click', () => show(idx - 1));
      document.getElementById('lb-next')!.addEventListener('click', () => show(idx + 1));

      dialog.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') show(idx + 1);
        if (e.key === 'ArrowLeft') show(idx - 1);
      });

      // swipe left/right to page; plain tap: left third = back, rest = forward
      let downX = 0;
      dialog.addEventListener('pointerdown', (e) => (downX = e.clientX));
      dialog.addEventListener('pointerup', (e) => {
        const t = e.target as HTMLElement;
        // let the close button, nav arrows, play button, and video controls handle their own clicks
        if (t.id === 'lb-close' || t.closest('#lb-nav') || t.closest('#lb-play') || t.closest('video')) return;
        const dx = e.clientX - downX;
        if (dx > 40) show(idx - 1);
        else if (dx < -40) show(idx + 1);
        else show(e.clientX < innerWidth / 3 ? idx - 1 : idx + 1);
      });

      dialog.addEventListener('close', () => {
        full.removeAttribute('src');
        vid.pause();
        vid.removeAttribute('src');
        play.hidden = true;
        window.scrollTo(0, scrollY);
      });

      // reactions: one per post per browser (localStorage), chosen emoji highlighted
      for (const box of document.querySelectorAll<HTMLElement>('.reactions')) {
        const id = box.dataset.id!;
        const key = `reacted-${id}`;
        const mark = () => {
          const chosen = localStorage.getItem(key);
          if (!chosen) return;
          for (const b of box.querySelectorAll<HTMLButtonElement>('button')) {
            b.classList.toggle('bg-neutral-200', b.dataset.emoji === chosen);
          }
        };
        mark();
        box.addEventListener('click', async (e) => {
          const btn = (e.target as HTMLElement).closest('button');
          if (!btn) return;
          const emoji = btn.dataset.emoji!;
          const prev = localStorage.getItem(key);
          if (prev === emoji) return; // already reacted with this one
          localStorage.setItem(key, emoji);
          mark();
          const res = await fetch('/api/react', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, emoji, prev }),
          });
          const counts = await res.json();
          for (const b of box.querySelectorAll<HTMLButtonElement>('button')) {
            b.querySelector('span')!.textContent = counts[b.dataset.emoji!] || '';
          }
        });
      }

      // stable per-browser identity: remembers the name and ties comments to the same person
      // (and to their push subscription) without relying on the name, which can collide
      let commenterId = localStorage.getItem('commenter-id');
      if (!commenterId) {
        commenterId = crypto.randomUUID();
        localStorage.setItem('commenter-id', commenterId);
      }
      {
        const saved = localStorage.getItem('commenter-name');
        const forms = document.querySelectorAll<HTMLFormElement>(
          'form[action="/api/comment"], form[action="/api/reply"]',
        );
        for (const form of forms) {
          const nameEl = form.querySelector<HTMLInputElement>('input[name="name"]')!;
          form.querySelector<HTMLInputElement>('input[name="authorId"]')!.value = commenterId!;
          if (saved) nameEl.value = saved;
          form.addEventListener('submit', () => localStorage.setItem('commenter-name', nameEl.value.trim()));
        }
      }

      // comment reaction bubble (hover on desktop, tap on touch) + a reply button in it
      for (const comment of document.querySelectorAll<HTMLElement>('.comment')) {
        const bubble = comment.querySelector<HTMLElement>('.react-bubble')!;
        const summary = comment.querySelector<HTMLElement>('.creaction-summary')!;
        const postId = comment.dataset.post!;
        const key = comment.dataset.key!;
        const lsKey = `creacted-${postId}-${key}`;
        const show = () => {
          bubble.classList.remove('hidden');
          bubble.classList.add('flex');
        };
        const hide = () => {
          bubble.classList.add('hidden');
          bubble.classList.remove('flex');
        };

        comment.addEventListener('mouseenter', show);
        comment.addEventListener('mouseleave', hide);
        comment.querySelector('.comment-text')!.addEventListener('click', (e) => {
          e.stopPropagation();
          bubble.classList.contains('hidden') ? show() : hide();
        });

        for (const btn of bubble.querySelectorAll<HTMLButtonElement>('[data-emoji]')) {
          btn.addEventListener('click', async (e) => {
            e.stopPropagation();
            hide();
            const emoji = btn.dataset.emoji!;
            const prev = localStorage.getItem(lsKey);
            if (prev === emoji) return; // already reacted with this one
            localStorage.setItem(lsKey, emoji);
            const res = await fetch('/api/comment-react', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: postId, key, emoji, prev }),
            });
            if (!res.ok) return;
            const counts = await res.json();
            const entries = Object.entries(counts);
            summary.hidden = entries.length === 0;
            // build with textContent, never innerHTML, so a stored value can never be markup
            summary.replaceChildren(
              ...entries.map(([em, n]) => {
                const s = document.createElement('span');
                s.textContent = `${em} ${n}`;
                return s;
              }),
            );
          });
        }

        comment.querySelector('.bubble-reply')!.addEventListener('click', (e) => {
          e.stopPropagation();
          hide();
          const form = comment.querySelector<HTMLElement>('.reply-form')!;
          form.classList.remove('hidden');
          form.querySelector('textarea')?.focus();
        });
      }
      // tap outside closes any open bubble
      document.addEventListener('click', () => {
        for (const b of document.querySelectorAll('.react-bubble')) {
          b.classList.add('hidden');
          b.classList.remove('flex');
        }
      });
      // cancel buttons re-hide the form they're in
      for (const b of document.querySelectorAll('.reply-cancel')) {
        b.addEventListener('click', () => b.closest('.reply-form')?.classList.add('hidden'));
      }
      for (const b of document.querySelectorAll('.comment-cancel')) {
        b.addEventListener('click', () => b.closest('details')?.removeAttribute('open'));
      }

      // "Get notified" — web push, with per-platform install handling
      (async () => {
        const wrap = document.getElementById('notify');
        const btn = document.getElementById('notify-btn') as HTMLButtonElement | null;
        const msg = document.getElementById('notify-msg');
        if (!wrap || !btn || !msg) return; // no posts yet
        const show = (label: string, note = '') => {
          btn.textContent = label;
          btn.hidden = !label;
          msg.textContent = note;
          wrap.classList.remove('opacity-0');
        };

        const supported = 'serviceWorker' in navigator && 'PushManager' in window && 'Notification' in window;
        if (!supported) return; // leave hidden
        const keyRes = await fetch('/api/vapid-key');
        if (keyRes.status !== 200) return; // push not configured server-side → stay hidden
        const vapidKey = (await keyRes.text()).trim();

        const urlB64ToUint8Array = (b64: string) => {
          const pad = '='.repeat((4 - (b64.length % 4)) % 4);
          const raw = atob((b64 + pad).replace(/-/g, '+').replace(/_/g, '/'));
          return Uint8Array.from([...raw].map((c) => c.charCodeAt(0)));
        };
        const appKey = urlB64ToUint8Array(vapidKey);
        const sameKey = (a: ArrayBuffer | null) =>
          !!a && new Uint8Array(a).every((b, i) => b === appKey[i]) && a.byteLength === appKey.length;

        // register the subscription (upsert), attaching the commenter's name if we know it
        const postSub = (sub: PushSubscription) =>
          fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              ...sub.toJSON(),
              name: localStorage.getItem('commenter-name') || undefined,
              authorId: localStorage.getItem('commenter-id') || undefined,
            }),
          });

        const reg = await navigator.serviceWorker.register('/sw.js');
        const existing = await reg.pushManager.getSubscription();
        if (existing) {
          if (sameKey(existing.options.applicationServerKey)) {
            postSub(existing); // sync name in case they've commented since subscribing
            show('', '🔔 You’ll be notified of new posts');
            return;
          }
          // subscription was made with a different VAPID key (server keys changed) —
          // Chrome won't let us re-subscribe with a new key until this one is gone
          await existing.unsubscribe();
        }

        const standalone =
          window.matchMedia('(display-mode: standalone)').matches || (navigator as any).standalone === true;
        const isIOS = /iP(hone|ad|od)/.test(navigator.userAgent);
        if (isIOS && !standalone) {
          // iOS Safari has no in-browser install/permission API
          show('', 'To get notified on iPhone: tap Share, then “Add to Home Screen”.');
          return;
        }

        const subscribe = async () => {
          show('Enabling…');
          if ((await Notification.requestPermission()) !== 'granted') {
            show('', 'Notifications are blocked — enable them in your browser settings.');
            return;
          }
          try {
            const sub = await reg.pushManager.subscribe({
              userVisibleOnly: true,
              applicationServerKey: appKey,
            });
            await postSub(sub);
            show('', '🔔 You’ll be notified of new posts');
          } catch (err) {
            console.error('push subscribe failed', err);
            show('Try again', 'Couldn’t enable notifications — check your connection and retry.');
          }
        };

        show('🔔 Get notified of new posts');
        btn.addEventListener('click', subscribe);
      })();
    </script>
  </body>
</html>
