---
// Gated by the admin session cookie (see lib/auth); not signed in → back to the login page.
import '../../../styles/global.css';
import site from '../../../../site.json';
import { readPosts } from '../../../lib/store';
import { COUNTRIES } from '../../../lib/countries';
import { isAuthed } from '../../../lib/auth';

if (!isAuthed(Astro.cookies)) return Astro.redirect('/admin');

const post = (await readPosts()).find((p) => p.id === Astro.params.id);
if (!post) return new Response('Post not found', { status: 404 });

const fmt = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Edit post</title>
  </head>
  <body class="bg-neutral-50 text-neutral-800 antialiased">
    <div class="mx-auto max-w-xl px-4 py-16">
      <a href="/admin" class="text-sm text-neutral-500 hover:text-neutral-800">&larr; Admin</a>
      <h1 class="mt-2 mb-2 text-xl font-semibold text-neutral-900">Edit post</h1>
      <p class="mb-6 text-sm text-neutral-500">
        {post.images.length} photo{post.images.length === 1 ? '' : 's'} · published {fmt(post.createdAt)}
      </p>
      <div class="mb-8 flex gap-1.5 overflow-x-auto">
        {post.images.slice(0, 8).map((img) => (
          <img src={img.src} class="h-16 w-16 shrink-0 rounded object-cover" alt="" />
        ))}
        {post.images.length > 8 && (
          <span class="self-center pl-1 text-sm text-neutral-400">+{post.images.length - 8}</span>
        )}
      </div>

      <form method="post" action="/api/update" class="space-y-5">
        <input type="hidden" name="id" value={post.id} />
        <label class="block">
          <span class="text-sm font-medium">Title <span class="font-normal text-neutral-400">(optional)</span></span>
          <input
            type="text"
            name="title"
            value={post.title ?? ''}
            placeholder="Bangkok"
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium">Caption</span>
          <textarea
            name="caption"
            rows="4"
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          >{post.caption}</textarea>
        </label>
        <label class="block">
          <span class="text-sm font-medium">Album link <span class="font-normal text-neutral-400">(Ente or iCloud)</span></span>
          <input
            type="url"
            name="enteUrl"
            value={post.enteUrl ?? ''}
            placeholder={post.enteUrl ? undefined : 'Not stored for this post — paste it to re-sync'}
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          />
          <p id="icloud-note" hidden class="mt-1.5 text-xs text-amber-600">
            iCloud albums don't include location — pick a Country below so the globe still shows.
          </p>
        </label>
        <label class="block">
          <span class="text-sm font-medium">Country <span class="font-normal text-neutral-400">(draws the journey globe)</span></span>
          <select
            name="country"
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          >
            <option value="">—</option>
            {COUNTRIES.map((ct) => <option value={ct.code} selected={ct.code === post.country}>{ct.name}</option>)}
          </select>
        </label>
        <label class="block">
          <span class="text-sm font-medium">Posted by</span>
          <input
            type="text"
            name="author"
            value={post.author || site.defaultAuthor}
            maxlength="50"
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium">Date</span>
          <input
            type="date"
            name="date"
            value={post.createdAt.slice(0, 10)}
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          />
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" name="resync" class="h-4 w-4 accent-neutral-900" />
          <span class="text-sm">Re-download photos from the album (picks up added/removed photos)</span>
        </label>
        <div class="flex items-center justify-between">
          <button
            id="save"
            class="cursor-pointer rounded-lg bg-neutral-900 px-5 py-2.5 font-semibold text-white transition-colors hover:bg-neutral-700 disabled:cursor-wait disabled:bg-neutral-400"
          >
            Save
          </button>
          <button
            formaction="/api/delete"
            formnovalidate
            id="delete"
            class="cursor-pointer rounded-lg px-3 py-2.5 text-sm font-medium text-red-600 transition-colors hover:bg-red-50 disabled:text-neutral-400"
          >
            Delete post
          </button>
        </div>
        <div id="progress" hidden>
          <div class="h-2 overflow-hidden rounded-full bg-neutral-200">
            <div id="progress-bar" class="h-full w-0 rounded-full bg-neutral-900 transition-[width] duration-300"></div>
          </div>
          <p id="progress-label" class="mt-2 text-sm text-neutral-500"></p>
        </div>
        <p id="save-hint" class="text-sm leading-relaxed text-neutral-500">
          Re-syncing downloads and processes the whole album again — it can take a couple of minutes.
        </p>

        {post.comments && post.comments.length > 0 && (
          <div class="mt-8 border-t border-neutral-200 pt-6">
            <h2 class="mb-3 text-sm font-semibold text-neutral-700">Comments ({post.comments.length})</h2>
            <ul class="space-y-2">
              {post.comments.map((c, i) => (
                <li class="text-sm">
                  <div class="flex items-start gap-2">
                    <span class="flex-1">
                      <span class="font-medium">{c.name}</span>{' '}
                      <span class="whitespace-pre-wrap text-neutral-600">{c.text}</span>
                      <span class="block text-xs text-neutral-400">{fmt(c.createdAt)}</span>
                    </span>
                    <button
                      formaction="/api/comment-delete"
                      formnovalidate
                      name="ci"
                      value={i}
                      aria-label="Delete comment"
                      class="cdel shrink-0 cursor-pointer rounded px-2 py-1 leading-none text-red-600 hover:bg-red-50"
                    >&times;</button>
                  </div>
                  {c.replies?.map((r, ri) => (
                    <div class="mt-1 ml-4 flex items-start gap-2 border-l-2 border-neutral-200 pl-3">
                      <span class="flex-1">
                        <span class="font-medium">{r.name}</span>{' '}
                        <span class="whitespace-pre-wrap text-neutral-600">{r.text}</span>
                        <span class="block text-xs text-neutral-400">{fmt(r.createdAt)}</span>
                      </span>
                      <button
                        formaction="/api/reply-delete"
                        formnovalidate
                        name="ref"
                        value={`${c.createdAt}|${ri}`}
                        aria-label="Delete reply"
                        class="cdel shrink-0 cursor-pointer rounded px-2 py-1 leading-none text-red-600 hover:bg-red-50"
                      >&times;</button>
                    </div>
                  ))}
                </li>
              ))}
            </ul>
          </div>
        )}
      </form>
    </div>
    <script>
      const form = document.querySelector('form')!;
      const del = document.getElementById('delete') as HTMLButtonElement;
      del.addEventListener('click', (e) => {
        if (!confirm('Delete this post and its photos? This cannot be undone.')) e.preventDefault();
      });

      // iCloud shared albums carry no GPS — nudge toward a country for the globe
      const urlEl = form.querySelector('[name="enteUrl"]') as HTMLInputElement;
      const icloudNote = document.getElementById('icloud-note')!;
      const checkIcloud = () => (icloudNote.hidden = !/icloud\.com/i.test(urlEl.value));
      urlEl.addEventListener('input', checkIcloud);
      checkIcloud();
      for (const b of document.querySelectorAll('.cdel')) {
        b.addEventListener('click', (e) => {
          if (!confirm('Delete this comment?')) e.preventDefault();
        });
      }
      const progress = document.getElementById('progress')!;
      const bar = document.getElementById('progress-bar') as HTMLElement;
      const plabel = document.getElementById('progress-label')!;
      const saveHint = document.getElementById('save-hint')!;

      form.addEventListener('submit', async (e) => {
        const s = e.submitter as HTMLButtonElement;
        // delete / comment-delete / reply-delete buttons carry a formaction — let those submit
        // normally (they're quick and redirect). Only the Save button runs the async job.
        if (s?.getAttribute('formaction')) {
          for (const btn of form.querySelectorAll('button')) btn.disabled = true;
          if (s === del) s.textContent = 'Deleting…';
          return;
        }

        e.preventDefault();
        for (const btn of form.querySelectorAll('button')) btn.disabled = true;
        s.textContent = 'Saving…';

        const res = await fetch('/api/update', { method: 'POST', body: new FormData(form) });
        if (!res.ok) {
          progress.hidden = false;
          bar.classList.add('bg-red-600');
          plabel.textContent = await res.text();
          for (const btn of form.querySelectorAll('button')) btn.disabled = false;
          s.textContent = 'Save';
          return;
        }
        const { id } = await res.json();
        progress.hidden = false;
        saveHint.hidden = true;
        plabel.textContent = 'Saving…';

        const poll = setInterval(async () => {
          const st = await fetch(`/api/publish-status?id=${id}`).then((r) => (r.ok ? r.json() : null));
          if (!st) return;
          if (st.status === 'error') {
            clearInterval(poll);
            bar.classList.add('bg-red-600');
            plabel.textContent = `Failed: ${st.error}`;
            for (const btn of form.querySelectorAll('button')) btn.disabled = false;
            s.textContent = 'Save';
            return;
          }
          if (st.total > 0) {
            bar.style.width = `${Math.round((st.done / st.total) * 100)}%`;
            plabel.textContent = `Processing ${st.done} / ${st.total}…`;
          }
          if (st.status === 'done') {
            clearInterval(poll);
            bar.style.width = '100%';
            plabel.textContent = 'Done!';
            window.location.href = '/';
          }
        }, 1000);
      });
    </script>
  </body>
</html>
