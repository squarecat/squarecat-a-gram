---
// Gated by a session cookie — you enter the password once (see /api/login + lib/auth).
import '../styles/global.css';
import site from '../../site.json';
import { readPosts } from '../lib/store';
import { COUNTRIES } from '../lib/countries';
import { readSubscriptions } from '../lib/subscriptions';
import { adminEnabled, isAuthed } from '../lib/auth';

const authed = isAuthed(Astro.cookies);
const loginError = Astro.url.searchParams.has('error');
const posts = authed ? (await readPosts()).sort((a, b) => b.createdAt.localeCompare(a.createdAt)) : [];
const subs = authed ? await readSubscriptions() : [];
const namedSubs = subs.filter((s) => s.name).length;
const fmt = (iso: string) =>
  new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{authed ? 'New post' : 'Sign in'}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Butterfly+Kids&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-neutral-50 text-neutral-800 antialiased">
    {!authed && (
      <div class="mx-auto flex min-h-dvh max-w-sm flex-col justify-center px-4">
        <h1 class="font-hand mb-6 text-center text-4xl text-neutral-900">{site.name}</h1>
        {adminEnabled() ? (
          <form method="post" action="/api/login" class="space-y-3">
            <label class="block">
              <span class="text-sm font-medium">Password</span>
              <input
                type="password"
                name="password"
                required
                autofocus
                autocomplete="current-password"
                class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
              />
            </label>
            {loginError && <p class="text-sm text-red-600">Wrong password.</p>}
            <button class="w-full cursor-pointer rounded-lg bg-neutral-900 px-5 py-2.5 font-semibold text-white transition-colors hover:bg-neutral-700">
              Sign in
            </button>
          </form>
        ) : (
          <p class="text-center text-sm text-neutral-500">
            Admin is disabled — set <code>ADMIN_PASSWORD</code> on the server to enable it.
          </p>
        )}
        <p class="mt-8 text-center text-sm"><a href="/" class="text-neutral-500 hover:text-neutral-900">&larr; Back to the feed</a></p>
      </div>
    )}

    <div class="mx-auto max-w-xl px-4 py-16" style={authed ? '' : 'display:none'}>
      <div class="mb-8 flex items-baseline justify-between">
        <h1 class="text-xl font-semibold text-neutral-900">New post</h1>
        <span class="text-sm text-neutral-400">
          🔔 {subs.length} subscriber{subs.length === 1 ? '' : 's'}
          {namedSubs > 0 && ` (${namedSubs} named)`}
        </span>
      </div>
      <form method="post" action="/api/publish" class="space-y-5">
        <label class="block">
          <span class="text-sm font-medium">Album link <span class="font-normal text-neutral-400">(Ente or iCloud shared album)</span></span>
          <input
            type="url"
            name="enteUrl"
            required
            placeholder="https://…  (Ente ?t=…#…  or  icloud.com/sharedalbum/#…)"
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          />
          <p id="icloud-note" hidden class="mt-1.5 text-xs text-amber-600">
            iCloud albums don't include location — pick a Country below so the globe still shows.
          </p>
        </label>
        <label class="block">
          <span class="text-sm font-medium">Posted by</span>
          <input
            type="text"
            name="author"
            value={site.defaultAuthor}
            maxlength="50"
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium">Country <span class="font-normal text-neutral-400">(optional — draws the journey globe)</span></span>
          <select
            name="country"
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          >
            <option value="">—</option>
            {COUNTRIES.map((ct) => <option value={ct.code}>{ct.name}</option>)}
          </select>
        </label>
        <label class="block">
          <span class="text-sm font-medium">Date <span class="font-normal text-neutral-400">(optional — for backdating; empty = today)</span></span>
          <input
            type="date"
            name="date"
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium">Title <span class="font-normal text-neutral-400">(optional — e.g. a location, "Bangkok")</span></span>
          <input
            type="text"
            name="title"
            placeholder="Bangkok"
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium">Caption</span>
          <textarea
            name="caption"
            rows="4"
            class="mt-1.5 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 shadow-sm focus:border-neutral-500 focus:ring-0 focus:outline-none"
          ></textarea>
        </label>
        <button
          id="publish-btn"
          class="cursor-pointer rounded-lg bg-neutral-900 px-5 py-2.5 font-semibold text-white transition-colors hover:bg-neutral-700 disabled:cursor-wait disabled:bg-neutral-400"
        >
          Publish
        </button>
        <div id="progress" hidden>
          <div class="h-2 overflow-hidden rounded-full bg-neutral-200">
            <div id="progress-bar" class="h-full w-0 rounded-full bg-neutral-900 transition-[width] duration-300"></div>
          </div>
          <p id="progress-label" class="mt-2 text-sm text-neutral-500"></p>
        </div>
        <p id="publish-hint" class="text-sm leading-relaxed text-neutral-500">
          Publishing downloads and processes every photo in the album — it can take a couple of
          minutes. You can leave this page open; it'll take you to the feed when it's done.
        </p>
      </form>

      {posts.length > 0 && (
        <section class="mt-14">
          <h3 class="mb-4 text-sm font-semibold tracking-wide text-neutral-500 uppercase">Posts</h3>
          <ul class="divide-y divide-neutral-200 rounded-lg border border-neutral-200 bg-white">
            {posts.map((post) => (
              <li>
                <a href={`/admin/edit/${post.id}`} class="flex items-center gap-3 px-3 py-2.5 hover:bg-neutral-50">
                  <img src={post.images[0]?.src} class="h-12 w-12 shrink-0 rounded object-cover" alt="" />
                  <span class="min-w-0 flex-1">
                    <span class="block truncate text-sm">{post.title || post.caption || 'Untitled'}</span>
                    <span class="block text-xs text-neutral-400">
                      {fmt(post.createdAt)} · {post.images.length} photo{post.images.length === 1 ? '' : 's'}
                      {post.comments?.length ? ` · ${post.comments.length} comment${post.comments.length === 1 ? '' : 's'}` : ''}
                    </span>
                  </span>
                  <span class="text-sm text-neutral-400">Edit &rarr;</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>
    <script>
      // the compose form only exists when signed in; on the login page there's nothing to wire up
      const form = document.querySelector('form[action="/api/publish"]') as HTMLFormElement | null;
      if (form) {
      const btn = document.getElementById('publish-btn') as HTMLButtonElement;
      const progress = document.getElementById('progress')!;
      const bar = document.getElementById('progress-bar') as HTMLElement;
      const label = document.getElementById('progress-label')!;
      const hint = document.getElementById('publish-hint')!;

      // iCloud shared albums carry no GPS — nudge the author to pick a country for the globe
      const urlEl = form.querySelector('[name="enteUrl"]') as HTMLInputElement;
      const icloudNote = document.getElementById('icloud-note')!;
      const checkIcloud = () => (icloudNote.hidden = !/icloud\.com/i.test(urlEl.value));
      urlEl.addEventListener('input', checkIcloud);
      checkIcloud();

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        btn.disabled = true;
        btn.textContent = 'Publishing…';

        const res = await fetch('/api/publish', { method: 'POST', body: new FormData(form) });
        if (!res.ok) {
          // e.g. 401 wrong password
          label.textContent = await res.text();
          progress.hidden = false;
          bar.classList.add('bg-red-600');
          btn.disabled = false;
          btn.textContent = 'Publish';
          return;
        }
        const { id } = await res.json();
        progress.hidden = false;
        hint.hidden = true;
        label.textContent = 'Preparing…';

        const poll = setInterval(async () => {
          const s = await fetch(`/api/publish-status?id=${id}`).then((r) => (r.ok ? r.json() : null));
          if (!s) return;
          if (s.status === 'error') {
            clearInterval(poll);
            bar.classList.add('bg-red-600');
            label.textContent = `Failed: ${s.error}`;
            btn.disabled = false;
            btn.textContent = 'Publish';
            return;
          }
          if (s.total > 0) {
            bar.style.width = `${Math.round((s.done / s.total) * 100)}%`;
            label.textContent = `Processing ${s.done} / ${s.total}…`;
          }
          if (s.status === 'done') {
            clearInterval(poll);
            bar.style.width = '100%';
            label.textContent = 'Done!';
            window.location.href = '/';
          }
        }, 1000);
      });
      }
    </script>
  </body>
</html>
