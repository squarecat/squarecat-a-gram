# Copy to .env and fill in. Loaded automatically by the app (dotenv) and, in Docker,
# injected at runtime via docker-compose's `env_file` (never baked into the image).

# Required to publish/edit/delete via /admin
ADMIN_PASSWORD=change-me

# Public origin — needed in prod for correct unfurl / notification URLs
SITE_URL=https://feed.example.com

# Web push (optional). Generate once: npx web-push generate-vapid-keys
# All three must be set for the "Get notified" button and publish notifications to work.
# Keep VAPID_PRIVATE_KEY secret.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Ente museum API — set to https://api.ente.io for ente.io accounts
# ENTE_API_BASE=https://photos.squarecat.io/api
