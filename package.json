  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "start": "HOST=0.0.0.0 PORT=2987 node dist/server/entry.mjs",
    "selfcheck": "node --experimental-strip-types src/sources/ente.ts"
  },
  "dependencies": {
    "@astrojs/node": "^9",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^5",
    "bs58": "^6",
    "d3-geo": "^3.1.1",
    "dotenv": "^17.4.2",
    "heic-convert": "^2",
    "libsodium-wrappers": "^0.7",
    "opentype.js": "^2.0.0",
    "sharp": "^0.34",
    "tailwindcss": "^4.3.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/libsodium-wrappers": "^0.7",
    "@types/node": "^22",
    "@types/web-push": "^3.6.4"
  }
}
